local dragging, dragInput, dragStart, startPos

local function update(input)
    local delta = input.Position - dragStart
    MainFrame.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
end

TitleBar.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        dragging = true
        dragStart = input.Position
        startPos = MainFrame.Position
        
        input.Changed:Connect(function()
            if input.UserInputState == Enum.UserInputState.End then
                dragging = false
            end
        end)
    end
end)

TitleBar.InputChanged:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then
        dragInput = input
    end
end)

UserInputService.InputChanged:Connect(function(input)
    if input == dragInput and dragging then
        update(input)
    end
end)

local isUpsideDown = false
local loopConnection = nil

local function revertCharacter()
    if loopConnection then
        loopConnection:Disconnect()
        loopConnection = nil
    end
    
    local c = lp.Character
    if c then
        local hrp1 = c:FindFirstChild("FakeRoot")
        if hrp1 then
            local hrp0 = hrp1:FindFirstChild("HumanoidRootPart")
            if hrp0 then
                c.Parent = nil
                hrp0.Parent = c
                
                local rootJoint = hrp0:FindFirstChild("RootJoint")
                if rootJoint then
                    local origPart0 = hrp0:GetAttribute("OriginalPart0")
                    if origPart0 then
                        local p0 = c:FindFirstChild(origPart0)
                        if p0 then 
                            rootJoint.Part0 = p0 
                        end
                    end
                end
                
                hrp0.Transparency = 1
                hrp1:Destroy()
                c.Parent = workspace
            end
        end
    end
end

ToggleBtn.MouseButton1Click:Connect(function()
    local c = lp.Character
    if not c then return end
    
    if not isUpsideDown then
        isUpsideDown = true
        ToggleBtn.Text = "DISABLE"
        ToggleBtn.TextColor3 = Color3.fromRGB(255, 80, 80)
        
        local hrp0 = c:FindFirstChild("HumanoidRootPart")
        if not hrp0 then return end
        
        local hrp1 = hrp0:Clone()
        hrp1.Name = "FakeRoot"
        
        c.Parent = nil
        hrp0.Parent = hrp1
        
        local rootJoint = hrp0:FindFirstChild("RootJoint")
        if rootJoint then
            if rootJoint.Part0 then
                hrp0:SetAttribute("OriginalPart0", rootJoint.Part0.Name)
            end
            rootJoint.Part0 = nil
        end
        
        hrp1.Parent = c
        c.Parent = workspace
        
        hrp0.Transparency = 0.8
        
        loopConnection = RunService.Heartbeat:Connect(function()
            if c and c.Parent and hrp0 and hrp1 then
                hrp0.CFrame = hrp1.CFrame
                hrp0.Orientation += Vector3.new(0, 0, 180)
                hrp0.Position -= Vector3.new(0, 1, 0)
                hrp0.Velocity = hrp1.Velocity
            else
                revertCharacter()
                isUpsideDown = false
                ToggleBtn.Text = "ENABLE"
                ToggleBtn.TextColor3 = Color3.fromRGB(200, 0, 0)
            end
        end)
        
    else
        isUpsideDown = false
        ToggleBtn.Text = "ENABLE"
        ToggleBtn.TextColor3 = Color3.fromRGB(200, 0, 0)
        revertCharacter()
    end
end)

CloseBtn.MouseButton1Click:Connect(function()
    revertCharacter()
    ScreenGui:Destroy()
end)
